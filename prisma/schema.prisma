datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Oshi {
  id          String
  name        String
  userEmail   String
  image       String?
  agency      String?   @default("にじさんじ")
  unit        String?
  mainGenre   String?
  createdAt   DateTime  @default(now())

  @@id([id, userEmail])
}

model UserPreference {
  id           String   @id @default(cuid())
  userEmail    String   @unique
  interests    String[] // アンケートで選んだ最大5つのタグ
  lastSurveyAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CachedVideo {
  id           String   @id
  title        String
  thumbnail    String
  channelTitle String
  channelId    String
  categories   String[] // カテゴリを配列に変更
  publishedAt  DateTime
  duration     String?
  viewCount    String?
  cachedAt     DateTime @default(now())

  @@index([channelId])
  @@index([publishedAt])
  @@index([categories])
}